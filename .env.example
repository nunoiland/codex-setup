# Placeholder environment contract for the codex-setting orchestrator.
# Never commit real values. Use external secret managers or local env injection.

# GitHub delivery (default path)
CODEX_GITHUB_AUTH_MODE=app
CODEX_GITHUB_APP_ID=
CODEX_GITHUB_INSTALLATION_ID=
CODEX_GITHUB_PRIVATE_KEY_PATH=
CODEX_GITHUB_PAT=
CODEX_ENABLE_LIVE_GITHUB=0
CODEX_GITHUB_REPOSITORY=
CODEX_GITHUB_REMOTE=origin
CODEX_GITHUB_REPO_VISIBILITY=private

# LLM / provider access
# Phase 1 does not require an OpenAI API key. Leave this unset unless a future workflow explicitly needs it.
# OPENAI_API_KEY=

# API-key-free CI and harness
CODEX_VALIDATE_REQUIRE_CODEX=0
CODEX_CI_EVIDENCE_DIR=
CODEX_WEB_QA_URL=
CODEX_WEB_QA_COMMAND=
CODEX_WEB_QA_TIMEOUT_SECONDS=15
CODEX_BROWSER_QA_ARTIFACT_DIR=
CODEX_AUTOMERGE_REQUIRED_CHECKS=pr-validate

# Optional Product Factory evolution layer (safe defaults; no secrets)
CODEX_OPERATOR_PLATFORM=paperclip
CODEX_PAPERCLIP_BASE_URL=
CODEX_PAPERCLIP_API_URL=
CODEX_PAPERCLIP_HERMES_AGENT_NAME=Hermes Engineer
CODEX_HERMES_ADAPTER_MODE=contract
CODEX_HERMES_COMMAND=hermes
CODEX_MEMORY_BACKEND=json
CODEX_GRAPHITI_BASE_URL=
CODEX_GRAPHITI_GROUP_ID=

# Optional external pattern layer (off by default; no external installs)
CODEX_EXTERNAL_TOOLS_MODE=off
CODEX_UNDERSTAND_ANYTHING_MODE=off
CODEX_UNDERSTAND_ANYTHING_PATH=
CODEX_TASTE_REVIEW_LEVEL=standard
CODEX_COPY_REVIEW_LEVEL=standard
CODEX_VERIFICATION_LOOP_MODE=contract

# Builder execution
CODEX_ENABLE_BUILDER_EXECUTION=0
CODEX_WEB_BUILDER_COMMAND=
CODEX_IOS_BUILDER_COMMAND=
CODEX_ANDROID_BUILDER_COMMAND=
CODEX_API_BUILDER_COMMAND=

# Reporting (default remains GitHub-first only)
CODEX_REPORTING_MODE=github_only

CODEX_DEFAULT_RETRY_LIMIT=1
# Local cron runner (safe defaults; no secrets)
CODEX_CRON_MODE=queue
CODEX_CRON_CWD=
CODEX_CRON_PYTHON=python3
CODEX_CRON_LOG_FILE=
CODEX_CRON_LOCK_DIR=
CODEX_CRON_MAX_RUNS=1
CODEX_CRON_MAX_IDLE_CYCLES=1
CODEX_CRON_POLL_SECONDS=1

# Optional metadata
CODEX_DEFAULT_GITHUB_OWNER=
CODEX_DEFAULT_BASE_BRANCH=main
CODEX_PROTECTED_BRANCHES=main,master
